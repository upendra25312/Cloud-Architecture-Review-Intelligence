{
  "version": "2.0",
  "functionTimeout": "00:45:00",
  "extensions": {
    "durableTask": {
      "hubName": "arbprodv1",
      "storageProvider": { "type": "azureStorage" },
      "maxConcurrentActivityFunctions": 3,
      "maxConcurrentOrchestratorFunctions": 5
    },
    "queues": {
      "batchSize": 1,
      "newBatchThreshold": 0,
      "visibilityTimeout": "00:10:00",
      "maxDequeueCount": 3
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  }
}
