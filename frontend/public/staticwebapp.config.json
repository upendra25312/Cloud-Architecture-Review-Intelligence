{
  "platform": {
    "apiRuntime": "node:20"
  },
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "userDetailsClaim": "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name",
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/5f51e0e9-4a52-494f-8068-27a3527967de/v2.0",
          "clientIdSettingName": "AZURE_CLIENT_ID",
          "clientSecretSettingName": "AZURE_CLIENT_SECRET"
        },
        "login": {
          "loginParameters": ["scope=openid profile email"]
        }
      }
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "X-Frame-Options": "DENY",
    "X-DNS-Prefetch-Control": "off",
    "Cross-Origin-Opener-Policy": "same-origin",
    "Permissions-Policy": "geolocation=(), microphone=(), camera=()",
    "Strict-Transport-Security": "max-age=31536000; includeSubDomains",
    "Content-Security-Policy": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.monitor.azure.com https://*.applicationinsights.azure.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://*.azure.com https://*.microsoftonline.com https://*.applicationinsights.azure.com https://dc.services.visualstudio.com https://learn.microsoft.com; form-action 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; upgrade-insecure-requests;"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/data/*",
      "/_next/*",
      "/*.css",
      "/*.js",
      "/*.json",
      "/*.ico",
      "/*.png",
      "/*.webp",
      "/*.svg"
    ]
  },
  "routes": [
    {
      "route": "/",
      "redirect": "/arb",
      "statusCode": 302
    },
    {
      "route": "/explorer",
      "redirect": "/services",
      "statusCode": 301
    },
    {
      "route": "/review-package",
      "redirect": "/arb",
      "statusCode": 301
    },
    {
      "route": "/my-project-reviews",
      "redirect": "/arb",
      "statusCode": 301
    },
    {
      "route": "/decision-center",
      "redirect": "/arb",
      "statusCode": 301
    },
    {
      "route": "/how-to-use",
      "redirect": "/arb",
      "statusCode": 301
    },
    {
      "route": "/demo",
      "allowedRoles": [
        "anonymous",
        "authenticated"
      ]
    },
    {
      "route": "/data-health",
      "allowedRoles": [
        "admin"
      ]
    },
    {
      "route": "/api/admin/*",
      "allowedRoles": [
        "admin"
      ]
    },
    {
      "route": "/api/arb/*",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/api/review-records",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/api/review-records/export",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/api/project-review-state",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/api/project-reviews",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/api/project-reviews/activate",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/api/project-reviews/archive",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/api/project-reviews/delete",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/api/project-reviews/purge",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/data/*",
      "headers": {
        "Cache-Control": "public, max-age=3600, stale-while-revalidate=86400"
      }
    },
    {
      "route": "/*.webp",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/*.png",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/*.svg",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/_next/static/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    }
  ]
}
