      "id": "943c168a-2ec2-a94c-8015-85732a1b4859",
      "text": "Auto Failover Groups can encompass one or multiple databases, usually used by the same app.",
      "description": "Failover Groups facilitate disaster recovery by configuring databases on one logical server to replicate to another region's logical server. This streamlines geo-replicated database management, offering a single endpoint for connection routing to replicated databases if the primary server fails.",
      "severity": "High",
      "service": "Azure SQL Database",
      "serviceCanonical": "Azure SQL Database",
      "serviceSlug": "azure-sql-database",
      "armService": "Microsoft.Sql/servers",
      "link": "https://learn.microsoft.com/en-us/azure/azure-sql/database/auto-failover-group-overview?tabs=azure-powershell",
      "graph": "// Azure Resource Graph Query\n// Provides a list of SQL databases that are not configured to use a failover-group.\nresources\n| where type =~'microsoft.sql/servers/databases'\n| where isnull(properties['failoverGroupId'])\n| project recommendationId = \"943c168a-2ec2-a94c-8015-85732a1b4859\", name, id, tags, param1= strcat(\"databaseId=\", properties['databaseId'])\n",
      "sourcePath": "checklists-ext/aprl_checklist.en.json",
      "sourceUrl": "https://github.com/Azure/review-checklists/blob/main/checklists-ext/aprl_checklist.en.json",
