    {
      "guid": "b2113023-a553-2e41-9789-597e2fb54c31",
      "technology": "APRL Checklist",
      "technologySlug": "aprl-checklist-aprl-checklist",
      "technologyStatus": "Preview",
      "technologyMaturityBucket": "Preview",
      "usageConfidence": "Medium",
      "technologyQualityScore": 89,
      "family": "APRL Checklist",
      "sourceKind": "checklists-ext",
      "checklist": "APRL Checklist",
      "category": "High Availability",
      "subcategory": "Microsoft.Web/serverFarms",
      "id": "b2113023-a553-2e41-9789-597e2fb54c31",
      "text": "Use Standard or Premium tier",
      "description": "Choose Standard/Premium Azure App Service Plan for robust apps with advanced scaling, high availability, better performance, and multiple slots, ensuring resilience and continuous operation.",
      "severity": "High",
      "service": "Azure App Service Plan",
      "serviceCanonical": "Azure App Service Plan",
      "serviceSlug": "azure-app-service-plan",
      "armService": "Microsoft.Web/serverFarms",
      "link": "https://learn.microsoft.com/en-us/azure/architecture/checklist/resiliency-per-service#app-service",
      "graph": "// Azure Resource Graph Query\n// Provides a list of Azure App Service Plans that are not in the \"Standard\", \"Premium\", or \"IsolatedV2\" SKU tiers.\n\nresources\n| where type =~ 'microsoft.web/serverfarms'\n| extend sku_tier = tostring(sku.tier)\n| where tolower(sku_tier) !contains \"standard\" and\n        tolower(sku_tier) !contains \"premium\" and\n        tolower(sku_tier) !contains \"isolatedv2\"\n| project recommendationId=\"b2113023-a553-2e41-9789-597e2fb54c31\", name, id, tags, param1= strcat(\"SKU=\",sku_tier)\n\n",
      "sourcePath": "checklists-ext/aprl_checklist.en.json",
      "sourceUrl": "https://github.com/Azure/review-checklists/blob/main/checklists-ext/aprl_checklist.en.json",
      "normalizedAt": "2026-05-08T18:00:27.107Z",
